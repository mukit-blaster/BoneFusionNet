_SUMMARY_COLS = [
    'model', 'aug_cond',
    'auc_roc', 'auc_pr', 'accuracy', 'balanced_accuracy',
    'sensitivity', 'specificity', 'f1_macro', 'mcc',
    'brier_score', 'ece', 'optimal_threshold', 'temperature',
]


def print_and_save_summary(all_results: dict, save_dir: str) -> pd.DataFrame:
    rows = []
    for tag, m in all_results.items():
        model_name, aug_cond = tag.rsplit('__', 1)
        row = {'model': model_name, 'aug_cond': aug_cond}
        for col in _SUMMARY_COLS[2:]:
            row[col] = round(float(m.get(col, float('nan'))), 4)
        rows.append(row)

    df_sum = pd.DataFrame(rows, columns=_SUMMARY_COLS)
    df_sum = df_sum.sort_values('auc_pr', ascending=False).reset_index(drop=True)

    csv_path = os.path.join(save_dir, "summary_all_models.csv")
    df_sum.to_csv(csv_path, index=False)

    print("\n" + "="*105)
    print("üìä  SUMMARY ‚Äî ALL MODELS √ó CONDITIONS  (sorted by AUC-PR ‚Üì)")
    print("="*105)
    col_w = {'model': 22, 'aug_cond': 10,
              **{c: 9 for c in _SUMMARY_COLS[2:]}}
    header = "".join(f"{c:<{col_w.get(c,9)}}" for c in _SUMMARY_COLS)
    print(header)
    print("-" * len(header))
    for _, row in df_sum.iterrows():
        line = "".join(f"{str(row[c]):<{col_w.get(c,9)}}" for c in _SUMMARY_COLS)
        print(line)
    print("="*105)
    print(f"\n  ‚úÖ CSV saved: {csv_path}")
    return df_sum


