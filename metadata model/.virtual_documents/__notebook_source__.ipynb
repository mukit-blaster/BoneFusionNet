def map_gender(df):
    if df["gender"].dtype == object:
        m = {"M":0,"Male":0,"male":0,"F":1,"Female":1,"female":1}
        df["gender"] = df["gender"].map(m)
    else:
        if df["gender"].min() == 1 and df["gender"].max() == 2:
            df["gender"] = df["gender"] - 1
    return df

