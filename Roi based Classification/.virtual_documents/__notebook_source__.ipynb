        thr = m.get('optimal_threshold', 0.5)
        axes[k].set_title(
            f"Fold {k+1} (thr={thr:.2f})\n"
            f"Sens={tp/(tp+fn):.2f}  Spec={tn/(tn+fp):.2f}", fontsize=9)
